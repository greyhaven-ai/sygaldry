# Sygaldry Environment Variables
# Copy this file to .env and fill in your API keys

# ============================================================================
# REQUIRED: LLM Provider API Keys (at least one is required)
# ============================================================================

# OpenAI - Most agents use this by default
OPENAI_API_KEY=sk-...

# Anthropic - For Claude models (alternative to OpenAI)
ANTHROPIC_API_KEY=sk-ant-...

# Google - For Gemini models (alternative to OpenAI)
GOOGLE_API_KEY=...

# Mistral - For Mistral models (alternative to OpenAI)
MISTRAL_API_KEY=...


# ============================================================================
# OPTIONAL: Web Search & Data Collection (enhances specific agents)
# ============================================================================

# Exa AI - For advanced web search, research agents, hallucination detection
# Required by: academic_research, research_assistant, hallucination_detector,
#              dataset_builder, recruiting_assistant, sourcing_assistant,
#              sales_intelligence, market_intelligence, web_search_agent
# Get it from: https://exa.ai
EXA_API_KEY=...

# Nimble - For web search, SERP data, and maps API
# Required by: web_search_agent (nimble mode), nimble_search_tool
# Get it from: https://nimble.com
NIMBLE_API_KEY=...

# Firecrawl - For advanced web scraping
# Required by: firecrawl_scrape_tool
# Get it from: https://firecrawl.dev
FIRECRAWL_API_KEY=...


# ============================================================================
# OPTIONAL: Developer & Integration Tools
# ============================================================================

# GitHub - For code search and repository access
# Required by: git_repo_search_tool, github_issues tool
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# YouTube - For video search and transcript extraction
# Required by: youtube_video_search_tool
# Get it from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=...


# ============================================================================
# OPTIONAL: Database Connections
# ============================================================================

# PostgreSQL - For database operations and agent state
# Required by: pg_search_tool, sqlalchemy_db (if using PostgreSQL)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:pass@localhost:5432/dbname


# ============================================================================
# OPTIONAL: Customer Support & Ticketing
# ============================================================================

# Zendesk - For helpdesk integration
# Required by: helpdesk_integration tool
# Get it from: Your Zendesk account settings
ZENDESK_API_TOKEN=...
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=admin@yourcompany.com


# ============================================================================
# OPTIONAL: Observability & Monitoring
# ============================================================================

# Lilypad - For LLM observability (optional but recommended)
# Get it from: https://lilypad.so
LILYPAD_API_KEY=...
